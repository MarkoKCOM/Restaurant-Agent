# Database
DATABASE_URL=postgresql://openseat:openseat@localhost:5432/openseat
REDIS_URL=redis://localhost:6379

# Auth — CHANGE THESE IN PRODUCTION
JWT_SECRET=change-me-in-production
ADMIN_SEED_PASSWORD=change-me-admin-password

# Seed accounts (optional — used by db:seed)
SUPER_ADMIN_SEED_EMAIL=admin@openseat.io
SUPER_ADMIN_SEED_PASSWORD=change-me-super-admin
SUPER_ADMIN_SEED_NAME=Super Admin
EMPLOYEE_SEED_EMAIL=staff@openseat.io
EMPLOYEE_SEED_PASSWORD=change-me-employee
EMPLOYEE_SEED_NAME=Staff Member

# AI / Agent (optional — required for agent & chat features)
OPENROUTER_API_KEY=
AGENT_MODEL=google/gemini-2.5-flash
CHAT_MODEL=qwen/qwen3-coder:free

# App
NODE_ENV=development
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173

# Widget
WIDGET_API_URL=http://localhost:3001
