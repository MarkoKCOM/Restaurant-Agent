{
  "name": "@sable/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@sable/domain": "workspace:*",
    "fastify": "^5.3.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/jwt": "^9.0.0",
    "drizzle-orm": "^0.43.0",
    "postgres": "^3.4.0",
    "ioredis": "^5.6.0",
    "bullmq": "^5.40.0",
    "zod": "^3.24.0",
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.0",
    "tsc-alias": "^1.8.0",
    "typescript": "^5.8.0",
    "eslint": "^9.0.0",
    "@types/node": "^22.0.0"
  }
}
