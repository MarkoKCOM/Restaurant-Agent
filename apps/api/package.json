{
  "name": "@openseat/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/jwt": "^9.0.0",
    "@openseat/domain": "workspace:*",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.40.0",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.43.0",
    "fastify": "^5.3.0",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.6.0",
    "jsonwebtoken": "^9.0.3",
    "postgres": "^3.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.0.0",
    "tsc-alias": "^1.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
