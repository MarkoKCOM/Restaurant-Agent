{
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter @openseat/domain build && pnpm --filter @openseat/dashboard build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "http://204.168.227.45/api/:path*" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
